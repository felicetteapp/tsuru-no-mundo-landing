{{#> layout}}
<div class="view-mode-button-container">
    View as:
    <a href="/">list</a>
    <a href="/grid">grid</a>
</div>
<div class="slideshow-container">
    <div class="slideshow">
        <div class="slideshow-item">
            <img src="" alt="" />
        </div>
        <div class="slideshow-item --next">
            <img src="" alt="" />
        </div>
        <div class="slideshow-details">
            <span class="number"></span>
            <div class="location"></div>
        </div>
    </div>
</div>
<div class="slider-settings-container">
    <div class="slider-settings">
        <label for="slideRange">Slide Duration (ms):</label>
        <input type="range" min="100" max="5000" value="500" class="slider" step="100" id="slideRange">
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/gsap@3.15/dist/gsap.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/gsap@3.15/dist/TextPlugin.min.js"></script>
<script>

const data = [
    {{#each tsurus}}
    {number: "{{paddedNumber}}",location: "{{location.raw}}",thumbnail: "{{pathFromRoot img}}",color: "{{mainColorContrast}}",},
    {{/each}}
]



 document.addEventListener("DOMContentLoaded", (event) => {
    gsap.registerPlugin(TextPlugin)


    let duration = 1000;
    let currentIndex = 0;
    let timeoutId;
    let inputDebounceTimeoutId;
    const slideshowItem = document.querySelector(".slideshow-item");
    const slideshowImage = slideshowItem.querySelector("img");
    const slideshowDetails = document.querySelector(".slideshow-details");
    const nextSlideshowItem = document.querySelector(".slideshow-item.--next");
    const nextSlideshowImage = nextSlideshowItem.querySelector("img");
    const numberElement = document.querySelector(".slideshow-details .number");
    const locationElement = document.querySelector(".slideshow-details .location");

    function showSlide(index) {
        if(timeoutId) {
            clearTimeout(timeoutId);
        }
        const estimatedTransitionDuration = duration * 0.3;
        const transitionDuration = estimatedTransitionDuration > 1000 ? 1000 : estimatedTransitionDuration;
        const delayBetweenSlides = Math.max(duration - transitionDuration, 50);
        const tsuru = data[index];
        const img = new Image();
        slideshowDetails.style.setProperty("--main-color", tsuru.color);
        img.src = tsuru.thumbnail;
        gsap.set(nextSlideshowItem, { opacity: 0, "--blur": "1rem" });
        img.onload = () => {
            if(currentIndex !== index) {
                return;
            }
            nextSlideshowImage.src = tsuru.thumbnail;
            gsap.to(numberElement, { text: tsuru.number, duration: transitionDuration / 1000, easing:"circ.inOut"});
            gsap.to(locationElement, { text: tsuru.location, duration: transitionDuration / 1000, easing: "circ.inOut"});
            gsap.to(nextSlideshowItem, { opacity: 1, "--blur": "0px", duration: transitionDuration / 1000,easing: "circ.inOut", onComplete: () => {
                slideshowImage.src = tsuru.thumbnail;
                timeoutId = setTimeout(nextSlide, delayBetweenSlides);
            }});
        }
    }

    function nextSlide() {
        if(timeoutId) {
            clearTimeout(timeoutId);
        }
        currentIndex = (currentIndex + 1) % data.length;
        showSlide(currentIndex);
    }

    showSlide(currentIndex);


    const slideRange = document.getElementById("slideRange");
    slideRange.addEventListener("input", (event) => {
        if(inputDebounceTimeoutId) {
            clearTimeout(inputDebounceTimeoutId);
        }
        inputDebounceTimeoutId = setTimeout(() => {
            duration = event.target.value;
            nextSlide();
        }, 300);
    });

 });

</script>
{{/layout}}